# Copy to .env and fill in real values.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token

# Where the JSON booking store lives (path relative to project root or absolute)
BOOKINGS_FILE=./data/hotfix-bookings.json

# Jira custom field context for Client Environments (customfield_13235)
CLIENT_CONTEXT_ID=14042

# How long to keep a booking before auto-cleaning it as "abandoned" (days).
# The deploy-based cleanup (bookings whose version now appears in Jira as deployed)
# always runs regardless of age.
BOOKING_RETENTION_DAYS=180

# Comma-separated emails allowed to cancel ANY booking (not just their own).
# Optional; leave empty in most environments.
ADMIN_EMAILS=

# Uvicorn port
PORT=3001

# Teams notifications — bridge to the hotfix Teams chat.
# On every successful /book and /cancel, the app POSTs an Adaptive Card to
# the selected webhook. Get each URL from a Teams "Send webhook alerts to a
# chat" Workflow. Treat these URLs as secrets — anyone with them can post
# into the chat.
#
# TEAMS_TARGET picks which webhook is active:
#   prod   -> TEAMS_WEBHOOK_URL_PROD (the real chat everyone watches)
#   test   -> TEAMS_WEBHOOK_URL_TEST (a sandbox chat, safe to spam)
#   empty  -> notifications disabled (fine for local dev / tests)
# You can add more targets by convention: TEAMS_TARGET=staging looks up
# TEAMS_WEBHOOK_URL_STAGING. If TEAMS_TARGET is set but the matching URL is
# empty, notifications stay disabled — we never silently fall back to a
# different URL (would risk posting test messages to the wrong chat).
TEAMS_TARGET=
TEAMS_WEBHOOK_URL_PROD=
TEAMS_WEBHOOK_URL_TEST=

# Public URL of this app (no trailing slash), used to build the
# "Open in Hotfix Booking tool" button on Teams cards. If unset, the button
# is omitted. Example: https://hotfix-booking.your-company.com
APP_BASE_URL=
